[10.138096, "o", "\u001b[2m    get_status в†’ step  51  max_force  0.071  trend=decreasing\u001b[0m\r\n"]
[10.138119, "o", "\r\n\u001b[35m\u001b[1mВ» Forces fell from ~3 to ~0.1, but FIRE has no curvature model вЂ” it's dawdling in the tail. Switch optimizer WITHOUT restarting:\u001b[0m\r\n"]
[11.742898, "o", "\u001b[33m  в–¶ steer(\"switch_optimizer\", optimizer=\"LBFGS\")\u001b[0m\r\n"]
